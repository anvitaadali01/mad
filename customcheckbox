XML 

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.ccheckbox">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CustomCheckbox">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>

  kotlin 
  package com.example.ccheckbox

import androidx.appcompat.app.AppCompatActivity
import android.os.Bundle
import android.widget.Button
import android.widget.CheckBox
import android.widget.Toast

class MainActivity : AppCompatActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        val btn = findViewById<Button>(R.id.button1)
        val ckb3 = findViewById<CheckBox>(R.id.checkBox3)
        val ckb4 = findViewById<CheckBox>(R.id.checkBox4)

        btn.setOnClickListener {
            val sb = StringBuilder("Selected: ")
            
            if (ckb3.isChecked) {
                sb.append(ckb3.text).append(" ")
            }
            
            if (ckb4.isChecked) {
                sb.append(ckb4.text).append(" ")
            }
            
            if (!ckb3.isChecked && !ckb4.isChecked) {
                sb.append("Nothing")
            }

            Toast.makeText(this, sb.toString(), Toast.LENGTH_LONG).show()
        }
    }
}
