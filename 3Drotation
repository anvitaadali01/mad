XML 
<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.animation3rotation">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Animation3Rotation">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>

kotlin 
package com.example.animation3rotation

import androidx.appcompat.app.AppCompatActivity
import android.os.Bundle
import android.view.animation.AnimationUtils
import android.widget.ImageView

class MainActivity : AppCompatActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        val cakeIv = findViewById<ImageView>(R.id.cakeIv)
        val rotateAnim = AnimationUtils.loadAnimation(this, R.anim.rotate)

        cakeIv.setOnClickListener {
            cakeIv.startAnimation(rotateAnim)
        }
        
        // Also start it automatically to match the "Animation" feel
        cakeIv.startAnimation(rotateAnim)
    }
}
